PORT=4000
HOST_WORKER_PORT=4555

# Backend URL used by the Telegram bot process.
APPLY_ENGINE_URL=http://127.0.0.1:4000

# Use this for local laptop runs where backend and host worker run on the same host.
HOST_WORKER_URL=http://127.0.0.1:4555

# Use this instead when the backend runs inside Docker and the worker runs on the laptop host.
# HOST_WORKER_URL=http://host.docker.internal:4555

BROWSER_PROFILE_DIR=./data/browser-profiles
DEFAULT_RESUME_PATH=
TELEGRAM_BOT_TOKEN=
