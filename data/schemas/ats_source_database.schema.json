{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ats_source_database.schema.json",
  "title": "ATS Source Database",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "description", "sources"],
  "properties": {
    "version": {"const": 2},
    "description": {"type": "string", "minLength": 1},
    "source_schema": {"type": "object"},
    "sources": {
      "type": "array",
      "items": {"$ref": "#/$defs/source"}
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": ["company", "provider"],
      "properties": {
        "company": {"type": "string", "minLength": 1},
        "provider": {"type": "string", "enum": ["greenhouse", "lever", "ashby", "workday"]},
        "slug": {"type": "string", "minLength": 1},
        "job_board_name": {"type": "string", "minLength": 1},
        "api_url": {"type": "string", "format": "uri"},
        "career_url": {"type": "string", "format": "uri"},
        "region": {"type": "string", "enum": ["global", "eu"]},
        "host": {"type": "string", "minLength": 1},
        "tenant": {"type": "string", "minLength": 1},
        "site": {"type": "string", "minLength": 1},
        "applied_facets": {"type": "object"},
        "search_text": {"type": "string"}
      },
      "allOf": [
        {
          "if": {"properties": {"provider": {"const": "greenhouse"}}},
          "then": {"anyOf": [{"required": ["slug"]}, {"required": ["api_url"]}]}
        },
        {
          "if": {"properties": {"provider": {"const": "lever"}}},
          "then": {"anyOf": [{"required": ["slug"]}, {"required": ["api_url"]}]}
        },
        {
          "if": {"properties": {"provider": {"const": "ashby"}}},
          "then": {
            "anyOf": [
              {"required": ["slug"]},
              {"required": ["job_board_name"]},
              {"required": ["api_url"]},
              {"required": ["career_url"]}
            ]
          }
        },
        {
          "if": {"properties": {"provider": {"const": "workday"}}},
          "then": {
            "anyOf": [
              {"required": ["api_url"]},
              {"required": ["career_url"]},
              {"required": ["host", "tenant", "site"]}
            ]
          }
        }
      ]
    }
  }
}
