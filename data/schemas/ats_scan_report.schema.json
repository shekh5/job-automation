{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ats_scan_report.schema.json",
  "title": "Combined ATS Scan Report",
  "description": "Backward-compatible output produced by scripts/fetch_jobs_ats.py.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "strategy",
    "providers",
    "checked",
    "errors",
    "source_repairs",
    "total_raw_jobs",
    "total_current_jobs",
    "freshness_days",
    "matches",
    "skipped_non_greenhouse",
    "total_greenhouse_jobs",
    "total_recent_greenhouse_jobs"
  ],
  "properties": {
    "schema_version": {"const": 2},
    "generated_at": {"type": "string", "format": "date-time"},
    "strategy": {"type": "string", "minLength": 1},
    "providers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["greenhouse", "lever", "ashby", "workday"],
      "properties": {
        "greenhouse": {"$ref": "#/$defs/provider_summary"},
        "lever": {"$ref": "#/$defs/provider_summary"},
        "ashby": {"$ref": "#/$defs/provider_summary"},
        "workday": {"$ref": "#/$defs/provider_summary"}
      }
    },
    "checked": {
      "type": "array",
      "items": {"$ref": "#/$defs/checked_source"}
    },
    "errors": {
      "type": "array",
      "items": {"$ref": "#/$defs/source_error"}
    },
    "source_repairs": {
      "type": "array",
      "items": {"$ref": "#/$defs/source_repair"}
    },
    "total_raw_jobs": {"type": "integer", "minimum": 0},
    "total_current_jobs": {"type": "integer", "minimum": 0},
    "freshness_days": {"type": "integer", "minimum": 1},
    "matches": {
      "type": "array",
      "items": {"$ref": "normalized_job.schema.json"}
    },
    "skipped_non_greenhouse": {
      "type": "array",
      "description": "Legacy compatibility field retained from the Greenhouse-only report.",
      "items": {"type": "object"}
    },
    "total_greenhouse_jobs": {"type": "integer", "minimum": 0},
    "total_recent_greenhouse_jobs": {"type": "integer", "minimum": 0}
  },
  "$defs": {
    "provider_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attempted",
        "successful",
        "total_raw_jobs",
        "total_current_jobs",
        "total_dropped_jobs"
      ],
      "properties": {
        "attempted": {"type": "integer", "minimum": 0},
        "successful": {"type": "integer", "minimum": 0},
        "total_raw_jobs": {"type": "integer", "minimum": 0},
        "total_current_jobs": {"type": "integer", "minimum": 0},
        "total_dropped_jobs": {"type": "integer", "minimum": 0}
      }
    },
    "checked_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "company",
        "source",
        "slug",
        "raw_jobs",
        "recent_jobs",
        "matches",
        "dropped_jobs"
      ],
      "properties": {
        "company": {"type": "string", "minLength": 1},
        "source": {"type": "string", "enum": ["greenhouse", "lever", "ashby", "workday"]},
        "slug": {"type": "string"},
        "raw_jobs": {"type": "integer", "minimum": 0},
        "recent_jobs": {"type": "integer", "minimum": 0},
        "matches": {"type": "integer", "minimum": 0},
        "dropped_jobs": {"type": "integer", "minimum": 0}
      }
    },
    "source_error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["company", "source", "slug", "error"],
      "properties": {
        "company": {"type": "string", "minLength": 1},
        "source": {"type": "string", "minLength": 1},
        "slug": {"type": "string"},
        "error": {"type": "string", "minLength": 1}
      }
    },
    "source_repair": {
      "type": "object",
      "additionalProperties": false,
      "required": ["company", "source", "repairs"],
      "properties": {
        "company": {"type": "string", "minLength": 1},
        "source": {"type": "string", "enum": ["greenhouse", "lever", "ashby", "workday"]},
        "repairs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      }
    }
  }
}
